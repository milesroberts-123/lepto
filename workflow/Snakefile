import pandas as pd

configfile: "../config/config.yaml"

samples = pd.read_csv(config["samples_table"], sep="\t").to_dict("records")
groups = sorted(set(s["group"] for s in samples))
samples_by_group = {
    g: [s["sample_id"] for s in samples if s["group"] == g]
    for g in groups
}
sample_ids = [str(s["sample_id"]) for s in samples]
cram_paths = dict(zip(sample_ids, [s["cram_path"] for s in samples]))

rule all:
    input:
        expand("results/assembly/{group}_assembly.fasta", group=groups)

include: "rules/kmc.smk"
